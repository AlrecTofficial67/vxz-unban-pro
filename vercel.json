{
  "version": 2,
  "routes": [
    {"src": "/style.css", "headers": {"Content-Type": "text/css"}, "dest": "/style.css"},
    {"src": "/app.js", "headers": {"Content-Type": "application/javascript"}, "dest": "/app.js"},
    {"src": "/config.js", "headers": {"Content-Type": "application/javascript"}, "dest": "/config.js"},
    {"src": "/(.*)", "dest": "/index.html"}
  ]
}
